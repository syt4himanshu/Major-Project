NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database Configuration
# Development: Use local PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/pds
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/pds_test

# Production: Use Neon or Render PostgreSQL with SSL
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# CORS Configuration
# Comma-separated trusted browser origins.
# Development: Allow localhost ports
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Production: Set ONLY your real HTTPS domains
# CORS_ORIGINS=https://pds-frontend.onrender.com

# Development override: allow any Origin header when NODE_ENV!=production.
# Set to false to enforce CORS_ORIGINS even in development.
CORS_ALLOW_ALL_DEV_ORIGINS=true

# JWT Configuration
# SECURITY: Generate a strong random secret for production (min 32 characters)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# Twilio Configuration (for OTP)
# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

