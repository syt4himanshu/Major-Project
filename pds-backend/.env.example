NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:password@localhost:5432/pds
TEST_DATABASE_URL=postgresql://himanshumire@localhost:5432/ration_db_test

# Comma-separated trusted browser origins.
# In production set ONLY your real HTTPS domains.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Development override: allow any Origin header when NODE_ENV!=production.
# Set to false to enforce CORS_ORIGINS even in development.
CORS_ALLOW_ALL_DEV_ORIGINS=true

JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
